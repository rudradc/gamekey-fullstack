else
  export NODE_PATH="/mnt/c/Users/Rudra Naryan/Downloads/gamekey-fullstack/gamekey-fullstack/frontend/node_modules/.pnpm/ansi-html-community@0.0.8/node_modules/ansi-html-community/node_modules:/mnt/c/Users/Rudra Naryan/Downloads/gamekey-fullstack/gamekey-fullstack/frontend/node_modules/.pnpm/ansi-html-community@0.0.8/node_modules:/mnt/c/Users/Rudra Naryan/Downloads/gamekey-fullstack/gamekey-fullstack/frontend/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../../../ansi-html-community/bin/ansi-html" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../ansi-html-community/bin/ansi-html" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../../../ansi-html-community/bin/ansi-html" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../../../ansi-html-community/bin/ansi-html" "$@"
else
